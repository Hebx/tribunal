{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@tribunal/sdk/memory": ["../sdk/dist/src/memory/index"],
      "@tribunal/sdk/memory/verdict": ["../sdk/dist/src/memory/verdict"],
      "@tribunal/sdk/memory/walrus": ["../sdk/dist/src/memory/walrus"],
      "@tribunal/sdk/memory/embeddings": ["../sdk/dist/src/memory/embeddings"],
      "@tribunal/sdk/memory/seal": ["../sdk/dist/src/memory/seal"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
